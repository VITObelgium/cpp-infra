{
  "$schema": "https://cmake.org/cmake/help/latest/_downloads/3e2d73bff478d88a7de0de736ba5e361/schema.json",
  "version": 10,
  "include": ["vcpkg_overlay/CMakePresets.json"],
  "configurePresets": [
    {
      "name": "vcpkg",
      "cacheVariables": {
        "CMAKE_TOOLCHAIN_FILE": "$env{VCPKG_ROOT}/scripts/buildsystems/vcpkg.cmake",
        "VCPKG_MANIFEST_INSTALL": "OFF",
        "VCPKG_MANIFEST_FEATURES": "cliprogress;process;hashing;xml;tbb;numeric;charset;compression;gdal;db;testing",
        "VCPKG_INSTALLED_DIR": "${sourceDir}/vcpkg_installed"
      },
      "environment": {
        "VCPKG_OVERLAY_TRIPLETS": "${sourceDir}/vcpkg_triplets"
      }
    },
    {
      "name": "default",
      "binaryDir": "${sourceDir}/build/cpp-infra-${presetName}",
      "inherits": ["vcpkg-base"],
      "cacheVariables": {
        "INFRA_LOGGING": "ON",
        "INFRA_GDAL": "ON",
        "INFRA_XML": "ON",
        "INFRA_TBB": "ON",
        "INFRA_NUMERIC": "OFF",
        "INFRA_CHARSET": "ON",
        "INFRA_PROCESS": "ON",
        "INFRA_DATABASE": "ON",
        "INFRA_DATABASE_SQLITE": "ON",
        "INFRA_DATABASE_POSTGRES": "ON",
        "INFRA_HASHING": "ON",
        "INFRA_COMPRESSION": "ON",
        "INFRA_COMPRESSION_ZSTD": "ON",
        "INFRA_ENABLE_TESTS": "ON",
        "INFRA_CLI_PROGRESS": "ON",
        "VCPKG_MANIFEST_FEATURES": "cliprogress;process;hashing;xml;tbb;numeric;charset;compression;gdal;db;testing",
        "VCPKG_OVERLAY_PORTS": "${sourceDir}/vcpkg_overlay/ports",
        "VCPKG_OVERLAY_TRIPLETS": "${sourceDir}/vcpkg_overlay/triplets"
      }
    },
    {
      "name": "arm64-osx",
      "inherits": ["default", "build-system-ninja-multi", "triplet-arm64-osx"]
    },
    {
      "name": "x64-osx",
      "inherits": ["default", "build-system-ninja-multi", "triplet-x64-osx"]
    },
    {
      "name": "x64-windows-static",
      "inherits": [
        "default",
        "build-system-ninja-multi",
        "triplet-x64-windows-static"
      ],
      "cacheVariables": {
        "CMAKE_MSVC_RUNTIME_LIBRARY": "MultiThreaded$<$<CONFIG:Debug>:Debug>"
      }
    },
    {
      "name": "x64-windows-static-vs",
      "inherits": [
        "default",
        "build-system-visualstudio",
        "triplet-x64-windows-static"
      ],
      "cacheVariables": {
        "CMAKE_MSVC_RUNTIME_LIBRARY": "MultiThreaded$<$<CONFIG:Debug>:Debug>"
      }
    },
    {
      "name": "x64-linux",
      "inherits": ["default", "build-system-ninja-multi", "triplet-x64-linux"]
    },
    {
      "name": "arm64-linux",
      "inherits": ["default", "build-system-ninja-multi", "triplet-arm64-linux"]
    }
  ],
  "buildPresets": [
    {
      "name": "x64-linux-debug",
      "configurePreset": "x64-linux",
      "displayName": "Linux x64 Debug",
      "description": "Debug build",
      "configuration": "Debug"
    },
    {
      "name": "x64-linux-release",
      "configurePreset": "x64-linux",
      "displayName": "Linux x64 Release",
      "description": "Release build",
      "configuration": "Release"
    },
    {
      "name": "x64-windows-static-vs-debug",
      "configurePreset": "x64-windows-static-vs",
      "displayName": "Windows x64 Debug",
      "description": "Debug build",
      "configuration": "Debug"
    },
    {
      "name": "x64-windows-static-vs-release",
      "configurePreset": "x64-windows-static-vs",
      "displayName": "Windows x64 Release",
      "description": "Release build",
      "configuration": "Release"
    },
    {
      "name": "x64-windows-static-debug",
      "configurePreset": "x64-windows-static",
      "displayName": "Windows x64 Debug",
      "description": "Debug build",
      "configuration": "Debug"
    },
    {
      "name": "x64-windows-static-release",
      "configurePreset": "x64-windows-static",
      "displayName": "Windows x64 Release",
      "description": "Release build",
      "configuration": "Release"
    }
  ],
  "testPresets": [
    {
      "name": "x64-linux-debug",
      "configurePreset": "x64-linux",
      "description": "Unit tests",
      "configuration": "Debug"
    },
    {
      "name": "x64-linux-release",
      "configurePreset": "x64-linux",
      "description": "Unit tests",
      "configuration": "Release"
    },
    {
      "name": "x64-windows-static-debug",
      "description": "Unit tests",
      "configurePreset": "x64-windows-static-vs",
      "output": {
        "outputOnFailure": true
      }
    },
    {
      "name": "x64-windows-static-release",
      "description": "Unit tests",
      "configurePreset": "x64-windows-static",
      "output": {
        "outputOnFailure": true
      }
    },
    {
      "name": "x64-windows-static-vs-release",
      "description": "Unit tests",
      "configurePreset": "x64-windows-static-vs",
      "output": {
        "outputOnFailure": true
      }
    }
  ]
}
